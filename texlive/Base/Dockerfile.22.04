# ---------------------------------------------
# Overleaf TexLive Base (ayaka-notes/overleaf)
# Ubuntu 22.04
# ---------------------------------------------

# ---------------------------------------------
# How to pull? 
# $ docker pull ghcr.io/ayaka-notes/texlive-full:base
# How to build?
# $ docker build -t ghcr.io/ayaka-notes/texlive-full:base -f ./texlive/Base/Dockerfile.22.04 ./texlive/Base
# ---------------------------------------------

# This Dockerfile is used to build texlive-full:base
# And texlive:2024, texlive:2023 and so on are all based on this
# Base Image Contain fonts, apt-installed component
FROM ubuntu:22.04

# LABEL
# -----------------------------------
LABEL \
    org.opencontainers.image.title="Docker Image of TeXLive" \
    org.opencontainers.image.authors="ayaka-notes <public@ayaka.space>" \
    org.opencontainers.image.source="https://github.com/ayaka-notes/texlive-full" \
    org.opencontainers.image.licenses="MIT" \
    org.opencontainers.image.description="Overleaf TeXLive Image by ayaka-notes"

# Makes sure LuaTex cache is writable
# -----------------------------------
ENV TEXMFVAR=/tmp/texmf-var
RUN mkdir -p /tmp/texmf-var && chmod -R 777 /tmp

# Set ENV to noninteractive
# -----------------------------------
ENV DEBIAN_FRONTEND noninteractive

# Update to ensure dependencies are updated
# ------------------------------------------
ENV REBUILT_AFTER="2026-01-13"


# Set up tex user and home directory (match upstream)
# ---------------------------------------------------
RUN set -eux; \
    groupadd -g 1000 tex; \
    useradd -m -u 1000 -g 1000 -d /home/tex -s /bin/sh \
      -c "You are in a sandboxed container without access to outside resources ^_^" \
      tex; \
    passwd -d tex; \
    chmod 750 /home/tex


# Install dependencies
# --------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    adduser apt base-files base-passwd bash bsdutils chktex coreutils culmus culmus-fancy dash debconf debianutils default-jdk-headless diffutils dot2tex dpkg e2fsprogs findutils freeglut3 gcc-12-base ghostscript gnuplot gpgv graphviz grep gsfonts gzip hostname imagemagick init-system-helpers inkscape libacl1 libapt-pkg6.0 libattr1 libaudit-common libaudit1 libblkid1 libbz2-1.0 libc-bin libc6 libcap-ng0 libcap2 libcom-err2 libcrypt1 libcurl4 libdb5.3 libdebconfclient0 libexpat1 libext2fs2 libffi8 libfftw3-3 libfontconfig1 libfreetype6 libgcc-s1 libgcrypt20 libgdal30 libgmp10 libgnutls30 libgpg-error0 libgsl27 libgssapi-krb5-2 libhogweed6 libidn12 libidn2-0 libijs-0.35 libjbig2dec0 libjpeg8 libk5crypto3 libkeyutils1 libkrb5-3 libkrb5support0 liblcms2-2 liblz4-1 liblzma5 libmagick++-6.q16-8 libmount1 libncurses5 libncurses6 libncursesw6 libnettle8 libnsl2 libopenjp2-7 libosmesa6 libp11-kit0 libpam-modules libpam-modules-bin libpam-runtime libpam0g libpaper1 libpcre2-8-0 libpcre3 libpng16-16 libprocps8 libseccomp2 libselinux1 libsemanage-common libsemanage2 libsepol2 libsmartcols1 libss2 libssl3 libstdc++6 libsystemd0 libtasn1-6 libtiff5 libtinfo6 libtirpc-common libtirpc3 libudev1 libudunits2-0 libunistring2 libuuid1 libxml2 libxxhash0 libzstd1 login logsave lsb-base mawk mount ncurses-base ncurses-bin passwd perl perl-base procps python-is-python3 python3-pygments qpdf r-base-core sed sensible-utils strace sysvinit-utils t1-cyrillic tar time ttf-bitstream-vera ttf-mscorefonts-installer ubuntu-keyring usrmerge util-linux wget zlib1g make build-essential gfortran\
    && rm -rf /var/lib/apt/lists/*

# Install R packages (one shot, non-interactive, pinned repo)
# --------------------
# Install R packages (one shot, non-interactive, pinned repo)
# --------------------
RUN Rscript -e "options(repos=c(CRAN='https://packagemanager.posit.co/cran/2022-07-17')); \
    pkgs <- c( \
    'abind', 'acepack', 'ADGofTest', 'admisc', 'AER', 'agricolae', 'AlgDesign', 'alr4', 'animation', 'ash', 'askpass', 'assertthat', 'backports', 'base', 'base64enc', 'BayesFactor', 'bayesm', 'bayesplot', 'bayestestR', 'BB', 'bbmle', 'bdsmatrix', 'Benchmarking', 'betareg', 'BH', 'bibtex', 'bindr', 'Biobase', 'BiocGenerics', 'BiocManager', 'BiocVersion', 'bit', 'bit64', 'bitops', 'blavaan', 'blob', 'BMA', 'boot', 'brio', 'broom', 'bslib', 'ca', 'cachem', 'calculus', 'callr', 'car', 'carData', 'caret', 'cartogram', 'caTools', 'CDM', 'cellranger', 'changepoint', 'checkmate', 'chron', 'CircStats', 'circular', 'class', 'classInt', 'cli', 'clipr', 'cluster', 'cmna', 'coda', 'codetools', 'coin', 'collapse', 'colorspace', 'combinat', 'commonmark', 'compiler', 'compositions', 'CompQuadForm', 'conflicted', 'contfrac', 'copula', 'corpcor', 'correlation', 'corrplot', 'cowplot', 'coxme', 'coxphw', 'cpm', 'cpp11', 'crayon', 'crosstalk', 'cubature', 'curl', 'DAAG', 'data.table', 'datasets', 'datawizard', 'DBI', 'dbplyr', 'dcurver', 'deldir', 'dendextend', 'DEoptim', 'DEoptimR', 'Deriv', 'desc', 'deSolve', 'dfoptim', 'diagram', 'dials', 'DiceDesign', 'dichromat', 'diffobj', 'digest', 'distributional', 'doBy', 'doParallel', 'dotCall64', 'dplyr', 'DT', 'dtplyr', 'dynlm', 'e1071', 'earth', 'Ecdat', 'Ecfun', 'economiccomplexity', 'effects', 'effectsize', 'ellipse', 'ellipsis', 'elliptic', 'emmeans', 'eRm', 'estimability', 'evaluate', 'exactRankTests', 'expm', 'extrafont', 'extrafontdb', 'factoextra', 'FactoMineR', 'fansi', 'faraway', 'farver', 'fastICA', 'fastmap', 'fastmatch', 'fBasics', 'fda', 'fdrtool', 'fds', 'fdth', 'fftwtools', 'fGarch', 'filehash', 'flashClust', 'flexmix', 'FNN', 'fontawesome', 'forcats', 'foreach', 'forecast', 'foreign', 'formatR', 'Formula', 'fracdiff', 'frontier', 'fs', 'furrr', 'future', 'future.apply', 'gamlss', 'gamlss.data', 'gamlss.dist', 'gamm4', 'gargle', 'gdata', 'gdtools', 'GeneNet', 'generics', 'GenSA', 'geojsonsf', 'geometries', 'ggcorrplot', 'ggeffects', 'ggplot2', 'ggplot2movies', 'ggpubr', 'ggrepel', 'ggridges', 'ggsci', 'ggsignif', 'ggstatsplot', 'ggtext', 'glasso', 'glassoFast', 'glm2', 'glmnet', 'globals', 'glue', 'gmodels', 'gnm', 'goftest', 'googledrive', 'googlesheets4', 'gower', 'GPArotation', 'GPfit', 'gplots', 'graphics', 'grDevices', 'grid', 'gridBase', 'gridExtra', 'gridGraphics', 'gridSVG', 'gridtext', 'grImport', 'grImport2', 'gsl', 'gss', 'gsubfn', 'gtable', 'gtools', 'hardhat', 'haven', 'hdrcde', 'hexbin', 'highlight', 'highr', 'Hmisc', 'hms', 'hrbrthemes', 'HSAUR2', 'htmlTable', 'htmltools', 'htmlwidgets', 'httpuv', 'httr', 'hypergeo', 'ibdreg', 'ICS', 'ICSOutlier', 'ids', 'igraph', 'infer', 'InformationValue', 'inline', 'insight', 'ipred', 'IQCC', 'irlba', 'isoband', 'iterators', 'itertools', 'itsmr', 'JointAI', 'jpeg', 'jquerylib', 'jsonify', 'jsonlite', 'kableExtra', 'kernlab', 'KernSmooth', 'klaR', 'km.ci', 'KMsurv', 'knitr', 'ks', 'labeling', 'labelled', 'Lahman', 'lars', 'later', 'latex2exp', 'lattice', 'latticeExtra', 'lava', 'lavaan', 'lazyeval', 'leafem', 'leaflet', 'leaflet.providers', 'leafsync', 'leaps', 'LearnBayes', 'lemon', 'lhs', 'libcoin', 'lifecycle', 'listenv', 'littler', 'lm.beta', 'lme4', 'lmerTest', 'lmtest', 'locfit', 'locpol', 'lomb', 'longitudinal', 'loo', 'lpSolveAPI', 'lsmeans', 'ltm', 'lubridate', 'lwgeom', 'magick', 'magrittr', 'mapdata', 'mapproj', 'maps', 'maptools', 'markdown', 'MASS', 'mathjaxr', 'Matrix', 'MatrixModels', 'matrixStats', 'maxLik', 'maxstat', 'mc2d', 'mclust', 'mcmcse', 'memoise', 'MEMSS', 'meta', 'metadat', 'metafor', 'methods', 'mgcv', 'mice', 'micEcon', 'micEconIndex', 'microbenchmark', 'mime', 'miniUI', 'minqa', 'mirt', 'misc3d', 'miscTools', 'mistat', 'mitools', 'mlbench', 'mlmRev', 'mnormt', 'modeldata', 'ModelMetrics', 'modelr', 'modeltools', 'moments', 'mondate', 'msm', 'mstate', 'multcomp', 'multicool', 'munsell', 'mvtnorm', 'nanotime', 'network', 'nlme', 'nloptr', 'nls2', 'nlstools', 'NMF', 'nnet', 'nonlinearTseries', 'nonnest2', 'norm2', 'nortest', 'np', 'numDeriv', 'nycflights13', 'openair', 'OpenMx', 'openssl', 'openxlsx', 'optextras', 'optimx', 'oz', 'packcircles', 'paletteer', 'parallel', 'parallelly', 'parameters', 'parsnip', 'party', 'patchwork', 'pbapply', 'pbivnorm', 'pbkrtest', 'PBSmapping', 'pcaMethods', 'pcaPP', 'performance', 'PerformanceAnalytics', 'permute', 'pillar', 'pixmap', 'pkgbuild', 'pkgconfig', 'pkgKitten', 'pkgload', 'pkgmaker', 'PKPDmodels', 'plm', 'plogr', 'plot3D', 'plotly', 'plotmo', 'plotrix', 'pls', 'plyr', 'png', 'polyclip', 'polycor', 'polynom', 'popbio', 'PortfolioAnalytics', 'posterior', 'pracma', 'praise', 'prettyunits', 'prismatic', 'pROC', 'processx', 'prodlim', 'progress', 'progressr', 'promises', 'proto', 'proxy', 'ps', 'pso', 'pspline', 'psych', 'purrr', 'qcc', 'qicharts2', 'quadprog', 'quantmod', 'quantreg', 'questionr', 'qvcalc', 'R.cache', 'R.methodsS3', 'R.oo', 'R.utils', 'R6', 'rainbow', 'randomForest', 'randomizeR', 'randtests', 'rapidjsonr', 'rappdirs', 'raster', 'rbibutils', 'Rcgmin', 'RColorBrewer', 'Rcpp', 'RcppArmadillo', 'RcppCCTZ', 'RcppDate', 'RcppEigen', 'RcppParallel', 'RCurl', 'rdd', 'rddtools', 'Rdpack', 'rdrobust', 'readr', 'readstata13', 'readxl', 'recipes', 'registry', 'relaimpo', 'relimp', 'rematch', 'rematch2', 'reporttools', 'reprex', 'reshape', 'reshape2', 'rex', 'RGraphics', 'RHRV', 'rio', 'rjags', 'rJava', 'rjson', 'rlang', 'Rlinsolve', 'rmarkdown', 'rngtools', 'robustbase', 'ROI', 'ROI.plugin.quadprog', 'rpart', 'rpf', 'rprojroot', 'rrcov', 'rsample', 'RSQLite', 'rstan', 'rstantools', 'rstatix', 'rstudioapi', 'Rttf2pt1', 'rvest', 'Rvmmin', 'Ryacas', 's2', 'sandwich', 'sass', 'scales', 'scatterplot3d', 'selectr', 'setRNG', 'sf', 'sfheaders', 'shape', 'shiny', 'SixSigma', 'sjlabelled', 'sjmisc', 'sjPlot', 'sjstats', 'slam', 'slider', 'sm', 'soiltexture', 'sourcetools', 'sp', 'spam', 'SparseM', 'spatial', 'spatialreg', 'spatstat', 'spatstat.core', 'spatstat.data', 'spatstat.geom', 'spatstat.linnet', 'spatstat.random', 'spatstat.sparse', 'spatstat.utils', 'spc', 'spData', 'spdep', 'sphet', 'splines', 'splm', 'sqldf', 'SQUAREM', 'stabledist', 'StanHeaders', 'stargazer', 'stars', 'statmod', 'statnet.common', 'stats', 'stats4', 'statsExpressions', 'stringi', 'stringr', 'strucchange', 'styler', 'survey', 'survival', 'survminer', 'survMisc', 'svglite', 'sys', 'systemfonts', 'tcltk', 'TeachingDemos', 'tensor', 'tensorA', 'terra', 'testthat', 'texreg', 'TH.data', 'tibble', 'tidymodels', 'tidyr', 'tidyselect', 'tidyverse', 'tikzDevice', 'timeDate', 'timeSeries', 'tinytex', 'tis', 'tmap', 'tmaptools', 'tmvnsim', 'tools', 'tseries', 'TTR', 'tune', 'tzdb', 'ucminf', 'units', 'urca', 'utf8', 'utils', 'uuid', 'vcd', 'vcdExtra', 'vctrs', 'vegan', 'viridis', 'viridisLite', 'vroom', 'waldo', 'warp', 'waveslim', 'wavethresh', 'webshot', 'widgetframe', 'withr', 'wk', 'wooldridge', 'workflows', 'workflowsets', 'WRS2', 'xfun', 'xlsx', 'xlsxjars', 'XML', 'xml2', 'xtable', 'xts', 'yaml', 'yardstick', 'yuima', 'zeallot', 'zip', 'zoo'\
    ); \
    install.packages(pkgs, Ncpus=max(1, parallel::detectCores()-1)); \
    ok <- sapply(pkgs, requireNamespace, quietly=TRUE); \
    if (!all(ok)) stop(paste('Missing packages:', paste(names(ok)[!ok], collapse=', ')))"



# Install Extra fonts
COPY ./extrafonts /usr/share/fonts/


# Install fonts
# --------------------
RUN echo "ttf-mscorefonts-installer msttcorefonts/accepted-mscorefonts-eula select true" | debconf-set-selections \
&& apt-get update && apt-get install -y ttf-mscorefonts-installer \
&& apt update && apt search ^fonts | grep -o '^fonts[^/]*' | xargs apt install -y \
&& wget --quiet https://github.com/google/fonts/archive/main.tar.gz -O gf.tar.gz \
&& rm -rf /var/lib/apt/lists/* \
&& tar -xf gf.tar.gz \
&& mkdir -p /usr/share/fonts/truetype/google-fonts \
&& find $PWD/fonts-main/ -name "*.ttf" -exec install -m644 {} /usr/share/fonts/truetype/google-fonts/ \; || return 1 \
&& rm -f gf.tar.gz \
&& fc-cache -f && rm -rf /var/cache/*
