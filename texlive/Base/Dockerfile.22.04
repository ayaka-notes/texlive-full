# ---------------------------------------------
# Overleaf TexLive Base (ayaka-notes/overleaf)
# Ubuntu 22.04
# ---------------------------------------------

# ---------------------------------------------
# How to pull? 
# $ docker pull ghcr.io/ayaka-notes/texlive-full:base
# How to build?
# $ docker build -t ghcr.io/ayaka-notes/texlive-full:base -f ./texlive/Base/Dockerfile.22.04 ./texlive/Base
# ---------------------------------------------

# This Dockerfile is used to build texlive-full:base
# And texlive:2024, texlive:2023 and so on are all based on this
# Base Image Contain fonts, apt-installed component
FROM ubuntu:22.04

# LABEL
# -----------------------------------
LABEL \
    org.opencontainers.image.title="Docker Image of TeXLive" \
    org.opencontainers.image.authors="ayaka-notes <public@ayaka.space>" \
    org.opencontainers.image.source="https://github.com/ayaka-notes/texlive-full" \
    org.opencontainers.image.licenses="MIT" \
    org.opencontainers.image.description="Overleaf TeXLive Image by ayaka-notes"

# Makes sure LuaTex cache is writable
# -----------------------------------
ENV TEXMFVAR=/tmp/texmf-var
RUN mkdir -p /tmp/texmf-var && chmod -R 777 /tmp

# Set ENV to noninteractive
# -----------------------------------
ENV DEBIAN_FRONTEND noninteractive

# Update to ensure dependencies are updated
# ------------------------------------------
ENV REBUILT_AFTER="2026-01-13"


# Set up tex user and home directory (match upstream)
# ---------------------------------------------------
RUN set -eux; \
    groupadd -g 1000 tex; \
    useradd -m -u 1000 -g 1000 -d /home/tex -s /bin/sh \
      -c "You are in a sandboxed container without access to outside resources ^_^" \
      tex; \
    passwd -d tex; \
    chmod 750 /home/tex


# Install dependencies
# --------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    adduser apt base-files base-passwd bash bsdutils chktex coreutils culmus culmus-fancy dash debconf debianutils default-jdk-headless diffutils dot2tex dpkg e2fsprogs findutils freeglut3 gcc-12-base ghostscript gnuplot gpgv graphviz grep gsfonts gzip hostname imagemagick init-system-helpers inkscape libacl1 libapt-pkg6.0 libattr1 libaudit-common libaudit1 libblkid1 libbz2-1.0 libc-bin libc6 libcap-ng0 libcap2 libcom-err2 libcrypt1 libcurl4 libdb5.3 libdebconfclient0 libexpat1 libext2fs2 libffi8 libfftw3-3 libfontconfig1 libfreetype6 libgcc-s1 libgcrypt20 libgdal30 libgmp10 libgnutls30 libgpg-error0 libgsl27 libgssapi-krb5-2 libhogweed6 libidn12 libidn2-0 libijs-0.35 libjbig2dec0 libjpeg8 libk5crypto3 libkeyutils1 libkrb5-3 libkrb5support0 liblcms2-2 liblz4-1 liblzma5 libmagick++-6.q16-8 libmount1 libncurses5 libncurses6 libncursesw6 libnettle8 libnsl2 libopenjp2-7 libosmesa6 libp11-kit0 libpam-modules libpam-modules-bin libpam-runtime libpam0g libpaper1 libpcre2-8-0 libpcre3 libpng16-16 libprocps8 libseccomp2 libselinux1 libsemanage-common libsemanage2 libsepol2 libsmartcols1 libss2 libssl3 libstdc++6 libsystemd0 libtasn1-6 libtiff5 libtinfo6 libtirpc-common libtirpc3 libudev1 libudunits2-0 libunistring2 libuuid1 libxml2 libxxhash0 libzstd1 login logsave lsb-base mawk mount ncurses-base ncurses-bin passwd perl perl-base procps python-is-python3 python3-pygments qpdf r-base r-base-core sed sensible-utils strace sysvinit-utils t1-cyrillic tar time ttf-bitstream-vera ttf-mscorefonts-installer ubuntu-keyring usrmerge util-linux wget zlib1g\
    make cmake build-essential gfortran\
    libblas-dev liblapack-dev libcurl4-openssl-dev libssl-dev libxml2-dev libudunits2-dev gdal-bin libgdal-dev libgeos-dev\
    libmagick++-dev libbz2-dev libpcre2-dev \
    gnupg ca-certificates dirmngr\
    && rm -rf /var/lib/apt/lists/*

# Install Extra fonts
COPY ./extrafonts /usr/share/fonts/

# Install fonts
# --------------------
RUN echo "ttf-mscorefonts-installer msttcorefonts/accepted-mscorefonts-eula select true" | debconf-set-selections \
&& apt-get update && apt-get install -y ttf-mscorefonts-installer \
&& apt update && apt search ^fonts | grep -o '^fonts[^/]*' | xargs apt install -y \
&& wget --quiet https://github.com/google/fonts/archive/main.tar.gz -O gf.tar.gz \
&& rm -rf /var/lib/apt/lists/* \
&& tar -xf gf.tar.gz \
&& mkdir -p /usr/share/fonts/truetype/google-fonts \
&& find $PWD/fonts-main/ -name "*.ttf" -exec install -m644 {} /usr/share/fonts/truetype/google-fonts/ \; || return 1 \
&& rm -f gf.tar.gz \
&& fc-cache -f && rm -rf /var/cache/*

# Install R packages (one shot, non-interactive, pinned repo)
# --------------------
COPY ./install-r-package-22.04.R /tmp/install_r_packages.R
RUN Rscript /tmp/install_r_packages.R && rm -f /tmp/install_r_packages.R

# LANG=C.UTF−8 for R knitr
# --------------------
ENV LANG=C.UTF-8