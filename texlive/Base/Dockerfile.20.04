# ---------------------------------------------
# Overleaf TexLive Base (ayaka-notes/overleaf)
# Ubuntu 22.04
# ---------------------------------------------

# ---------------------------------------------
# How to pull? 
# $ docker pull ghcr.io/ayaka-notes/texlive-full:base
# How to build?
# $ docker build -t ghcr.io/ayaka-notes/texlive-full:base ./texlive/Base
# ---------------------------------------------

# This Dockerfile is used to build texlive-full:base
# And texlive:2024, texlive:2023 and so on are all based on this
# Base Image Contain fonts, apt-installed component
FROM ubuntu:20.04

# LABEL
# -----------------------------------
LABEL \
    org.opencontainers.image.title="Docker Image of TeXLive" \
    org.opencontainers.image.authors="ayaka-notes <public@ayaka.space>" \
    org.opencontainers.image.source="https://github.com/ayaka-notes/texlive-full" \
    org.opencontainers.image.licenses="MIT" \
    org.opencontainers.image.description="Overleaf TeXLive Image by ayaka-notes"

# Makes sure LuaTex cache is writable
# -----------------------------------
ENV TEXMFVAR=/tmp/texmf-var
RUN mkdir -p /tmp/texmf-var && chmod -R 777 /tmp

# Set ENV to noninteractive
# -----------------------------------
ENV DEBIAN_FRONTEND noninteractive

# Update to ensure dependencies are updated
# ------------------------------------------
ENV REBUILT_AFTER="2026-01-13"


# Set up tex user and home directory (match upstream)
# ---------------------------------------------------
RUN set -eux; \
    groupadd -g 1000 tex; \
    useradd -m -u 1000 -g 1000 -d /home/tex -s /bin/sh \
    -c "You are in a sandboxed container without access to outside resources ^_^" \
    tex; \
    passwd -d tex; \
    chmod 750 /home/tex


# Install dependencies
# --------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    adduser apt base-files base-passwd bash bsdutils bzip2 chktex coreutils culmus culmus-fancy dash debconf debianutils diffutils dot2tex dpkg e2fsprogs fdisk findutils freeglut3 gcc-10-base ghostscript gnuplot gpgv graphviz grep gsfonts gzip hostname imagemagick init-system-helpers inkscape libacl1 libapt-pkg6.0 libattr1 libaudit-common libaudit1 libblkid1 libbz2-1.0 libc-bin libc6 libcap-ng0 libcom-err2 libcrypt1 libcurl4 libdb5.3 libdebconfclient0 libext2fs2 libfdisk1 libffi7 libfontconfig1 libgcc-s1 libgcrypt20 libgdal26 libgmp10 libgnutls30 libgpg-error0 libhogweed5 libidn2-0 liblz4-1 liblzma5 libmagick++-6.q16-8 libmount1 libncurses5 libncurses6 libncursesw6 libnettle7 libp11-kit0 libpam-modules libpam-modules-bin libpam-runtime libpam0g libpcre2-8-0 libpcre3 libprocps8 libseccomp2 libselinux1 libsemanage-common libsemanage1 libsepol1 libsmartcols1 libss2 libstdc++6 libsystemd0 libtasn1-6 libtinfo6 libudev1 libudunits2-0 libunistring2 libuuid1 libxml2 libzstd1 login logsave lsb-base mawk mount ncurses-base ncurses-bin passwd perl perl-base procps python-is-python3 python3-pygments qpdf r-base r-base-core sed sensible-utils strace sysvinit-utils t1-cyrillic tar time ttf-bitstream-vera ttf-mscorefonts-installer ubuntu-keyring util-linux wget zlib1g \
    make cmake build-essential gfortran \
    libblas-dev liblapack-dev libcurl4-openssl-dev libssl-dev libxml2-dev libudunits2-dev gdal-bin libgdal-dev libgeos-dev\
    libmagick++-dev libbz2-dev libpcre2-dev \
    && rm -rf /var/lib/apt/lists/*

# Install R packages (one shot, non-interactive, pinned repo)
# --------------------
RUN Rscript -e "options(repos=c(CRAN='https://packagemanager.posit.co/cran/2020-07-22')); \
    pkgs <- c( \
    'abind', 'acepack', 'AER', 'agricolae', 'AlgDesign', 'alr4', 'animation', 'askpass', 'assertthat', 'backports', 'base', 'base64enc', 'bayesplot', 'BB', 'bdsmatrix', 'betareg', 'BH', 'bibtex', 'bindr', 'Biobase', 'BiocGenerics', 'BiocManager', 'BiocVersion', 'bit', 'bit64', 'bitops', 'blob', 'BMA', 'boot', 'broom', 'ca', 'callr', 'car', 'carData', 'caret', 'caTools', 'cellranger', 'changepoint', 'checkmate', 'chron', 'CircStats', 'circular', 'class', 'classInt', 'cli', 'clipr', 'cluster', 'coda', 'codetools', 'coin', 'colorspace', 'combinat', 'commonmark', 'compiler', 'conquer', 'corpcor', 'coxme', 'cpm', 'crayon', 'crosstalk', 'cubature', 'curl', 'DAAG', 'data.table', 'datasets', 'DBI', 'dbplyr', 'deldir', 'DEoptim', 'DEoptimR', 'Deriv', 'desc', 'dfoptim', 'diagram', 'dichromat', 'digest', 'doBy', 'doParallel', 'dotCall64', 'dplyr', 'dtplyr', 'dynlm', 'e1071', 'earth', 'economiccomplexity', 'effects', 'ellipsis', 'emmeans', 'estimability', 'evaluate', 'expm', 'fansi', 'farver', 'fastICA', 'fastmap', 'fastmatch', 'fBasics', 'fda', 'fdrtool', 'fdth', 'fGarch', 'filehash', 'flexmix', 'forcats', 'foreach', 'forecast', 'foreign', 'formatR', 'Formula', 'fracdiff', 'fs', 'gamlss', 'gamlss.data', 'gamlss.dist', 'gamm4', 'gbRd', 'gdata', 'GeneNet', 'generics', 'GenSA', 'ggplot2', 'ggplot2movies', 'ggridges', 'glasso', 'glassoFast', 'glm2', 'glmnet', 'glue', 'gmodels', 'gnm', 'goftest', 'gower', 'gplots', 'graphics', 'grDevices', 'grid', 'gridBase', 'gridExtra', 'gridGraphics', 'gss', 'gsubfn', 'gtable', 'gtools', 'haven', 'hexbin', 'highlight', 'highr', 'Hmisc', 'hms', 'HSAUR2', 'htmlTable', 'htmltools', 'htmlwidgets', 'httpuv', 'httr', 'ibdreg', 'igraph', 'InformationValue', 'inline', 'ipred', 'IQCC', 'irlba', 'isoband', 'iterators', 'itertools', 'jpeg', 'jsonlite', 'kedd', 'kernlab', 'KernSmooth', 'klaR', 'knitr', 'labeling', 'labelled', 'Lahman', 'lars', 'later', 'latex2exp', 'lattice', 'latticeExtra', 'lava', 'lazyeval', 'leaps', 'LearnBayes', 'libcoin', 'lifecycle', 'littler', 'lme4', 'lmtest', 'longitudinal', 'lsmeans', 'lubridate', 'magick', 'magrittr', 'mapdata', 'mapproj', 'maps', 'maptools', 'markdown', 'MASS', 'Matrix', 'MatrixModels', 'matrixStats', 'maxLik', 'memoise', 'MEMSS', 'methods', 'mgcv', 'mime', 'miniUI', 'minqa', 'misc3d', 'miscTools', 'mistat', 'mitools', 'mlbench', 'mlmRev', 'mnormt', 'ModelMetrics', 'modelr', 'modeltools', 'moments', 'mondate', 'multcomp', 'munsell', 'mvtnorm', 'nanotime', 'network', 'nlme', 'nloptr', 'nls2', 'nlstools', 'NMF', 'nnet', 'nortest', 'np', 'numDeriv', 'nycflights13', 'openair', 'openssl', 'openxlsx', 'optextras', 'optimx', 'oz', 'parallel', 'party', 'pbkrtest', 'PBSmapping', 'pcaMethods', 'pcaPP', 'PerformanceAnalytics', 'pillar', 'pixmap', 'pkgbuild', 'pkgconfig', 'pkgKitten', 'pkgload', 'pkgmaker', 'PKPDmodels', 'plm', 'plogr', 'plot3D', 'plotmo', 'plotrix', 'plyr', 'png', 'polyclip', 'popbio', 'PortfolioAnalytics', 'praise', 'prettyunits', 'pROC', 'processx', 'prodlim', 'progress', 'promises', 'proto', 'ps', 'pso', 'psych', 'purrr', 'qcc', 'quadprog', 'qualityTools', 'quantmod', 'quantreg', 'questionr', 'qvcalc', 'R.cache', 'R.methodsS3', 'R.oo', 'R.utils', 'R6', 'randomForest', 'randtests', 'raster', 'Rcgmin', 'RColorBrewer', 'Rcpp', 'RcppArmadillo', 'RcppCCTZ', 'RcppEigen', 'RCurl', 'Rdpack', 'readr', 'readstata13', 'readxl', 'recipes', 'registry', 'relaimpo', 'relimp', 'rematch', 'rematch2', 'reporttools', 'reprex', 'reshape', 'reshape2', 'rex', 'rio', 'rjson', 'rlang', 'Rlinsolve', 'rmarkdown', 'rngtools', 'robustbase', 'ROI', 'ROI.plugin.quadprog', 'rpart', 'rprojroot', 'rrcov', 'Rsolnp', 'RSQLite', 'rstudioapi', 'rvest', 'Rvmmin', 'sandwich', 'scales', 'scatterplot3d', 'selectr', 'setRNG', 'sf', 'shape', 'shiny', 'SixSigma', 'slam', 'soiltexture', 'sourcetools', 'sp', 'spam', 'SparseM', 'spatial', 'spatstat', 'spatstat.data', 'spatstat.utils', 'spc', 'spData', 'spdep', 'sphet', 'splines', 'splm', 'sqldf', 'SQUAREM', 'stabledist', 'statmod', 'stats', 'stats4', 'stringi', 'stringr', 'strucchange', 'styler', 'survey', 'survival', 'symbols', 'sys', 'tcltk', 'TeachingDemos', 'tensor', 'testthat', 'TH.data', 'tibble', 'tidyr', 'tidyselect', 'tidyverse', 'tikzDevice', 'timeDate', 'timeSeries', 'tinytex', 'tis', 'tools', 'truncnorm', 'tseries', 'TTR', 'ucminf', 'units', 'urca', 'utf8', 'utils', 'vcd', 'vcdExtra', 'vctrs', 'viridis', 'viridisLite', 'whisker', 'withr', 'wooldridge', 'xfun', 'xml2', 'xtable', 'xts', 'yaml', 'yuima', 'zeallot', 'zip', 'zoo' \
    ); \
    pkgs <- unique(pkgs); \
    base_pkgs <- rownames(installed.packages(priority='base')); \
    pkgs_nonbase <- setdiff(pkgs, base_pkgs); \
    if (!requireNamespace('BiocManager', quietly=TRUE)) install.packages('BiocManager'); \
    \
    bioc_available <- BiocManager::available(); \
    bioc_pkgs <- intersect(pkgs_nonbase, bioc_available); \
    cran_pkgs <- setdiff(pkgs_nonbase, bioc_pkgs); \
    if (length(bioc_pkgs)) BiocManager::install(bioc_pkgs, ask=FALSE, update=FALSE); \
    if (length(cran_pkgs)) install.packages(cran_pkgs, Ncpus=max(1, parallel::detectCores()-1)); \
    to_check <- pkgs_nonbase; \
    ok <- sapply(to_check, requireNamespace, quietly=TRUE); \
    if (!all(ok)) stop(paste('Missing packages:', paste(names(ok)[!ok], collapse=', ')))"


# Install Extra fonts
COPY ./extrafonts /usr/share/fonts/


# Install fonts
# --------------------
RUN echo "ttf-mscorefonts-installer msttcorefonts/accepted-mscorefonts-eula select true" | debconf-set-selections \
    && apt-get update && apt-get install -y ttf-mscorefonts-installer \
    && apt update && apt search ^fonts | grep -o '^fonts[^/]*' | xargs apt install -y \
    && wget --quiet https://github.com/google/fonts/archive/main.tar.gz -O gf.tar.gz \
    && rm -rf /var/lib/apt/lists/* \
    && tar -xf gf.tar.gz \
    && mkdir -p /usr/share/fonts/truetype/google-fonts \
    && find $PWD/fonts-main/ -name "*.ttf" -exec install -m644 {} /usr/share/fonts/truetype/google-fonts/ \; || return 1 \
    && rm -f gf.tar.gz \
    && fc-cache -f && rm -rf /var/cache/*
