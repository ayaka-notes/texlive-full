lo', 'RcppCCTZ', 'RcppDate', 'RcppEigen', 'RcppParallel', 'RcppProgress', 'RCurl', 'rdd', 'rddtools', 'Rdpack', 'rdrobust', 'reactable', 'reactR', 'readr', 'readstata13', 'readxl', 'recipes', 'RefManageR', 'reformulas', 'registry', 'relaimpo', 'relimp', 'rematch', 'rematch2', 'reporttools', 'reprex', 'reshape', 'reshape2', 'rex', 'RGraphics', 'RHRV', 'rio', 'riskRegression', 'rjags', 'rJava', 'rjson', 'rlang', 'Rlinsolve', 'rmarkdown', 'Rmpfr', 'rms', 'rngtools', 'robustbase', 'ROI', 'ROI.plugin.quadprog', 'ROI.plugin.symphony', 'ROOPSD', 'rootSolve', 'rpart', 'rpart', 'rpf', 'rprojroot', 'rrcov', 'rsample', 'RSQLite', 'rstan', 'rstantools', 'rstatix', 'rstpm2', 'rstudioapi', 'Rsymphony', 'Rttf2pt1', 'rvest', 'rworldmap', 'Ryacas', 's2', 'sampleSelection', 'sandwich', 'sass', 'scales', 'scatterplot3d', 'sde', 'segmented', 'selectr', 'servr', 'sessioninfo', 'setRNG', 'sf', 'sfcr', 'sfd', 'sfheaders', 'shape', 'shiny', 'SimDesign', 'SixSigma', 'sjlabelled', 'sjmisc', 'sjPlot', 'sjstats', 'slam', 'slider', 'slippymath', 'sm', 'snakecase', 'soiltexture', 'sommer', 'sourcetools', 'sp', 'spacesXYZ', 'spam', 'SparseM', 'sparsevctrs', 'spatial', 'spatial', 'spatialreg', 'spatstat', 'spatstat.data', 'spatstat.explore', 'spatstat.geom', 'spatstat.linnet', 'spatstat.model', 'spatstat.random', 'spatstat.sparse', 'spatstat.univar', 'spatstat.utils', 'spc', 'spData', 'spdep', 'sphet', 'splines', 'splm', 'sqldf', 'SQUAREM', 'stabledist', 'StanHeaders', 'stargazer', 'stars', 'statmod', 'statnet.common', 'stats', 'stats4', 'statsExpressions', 'stringdist', 'stringi', 'stringr', 'strucchange', 'styler', 'SuppDists', 'survey', 'survival', 'survival', 'survminer', 'survMisc', 'svglite', 'sys', 'systemfit', 'systemfonts', 'table1', 'tcltk', 'TeachingDemos', 'tensor', 'tensorA', 'terra', 'testthat', 'texreg', 'textshaping', 'TH.data', 'tibble', 'tidymodels', 'tidyr', 'tidyselect', 'tidyverse', 'tikzDevice', 'timechange', 'timeDate', 'timereg', 'timeSeries', 'tinytex', 'tis', 'tmap', 'tmaptools', 'tmvnsim', 'tools', 'triebeard', 'tseries', 'TTR', 'tune', 'tzdb', 'ucminf', 'units', 'urca', 'urltools', 'utf8', 'utils', 'uuid', 'V8', 'vars', 'vcd', 'vcdExtra', 'vctrs', 'vegan', 'VGAM', 'viridis', 'viridisLite', 'vroom', 'waldo', 'warp', 'waveslim', 'wavethresh', 'withr', 'wk', 'wooldridge', 'workflows', 'workflowsets', 'writexl', 'WRS2', 'xfun', 'xlsx', 'xlsxjars', 'XML', 'xml2', 'xtable', 'xts', 'yaml', 'yardstick', 'yuima', 'zeallot', 'zip', 'zoo' \
    ); \
    install.packages(pkgs, Ncpus=max(1, parallel::detectCores()-1)); \
    ok <- sapply(pkgs, requireNamespace, quietly=TRUE); \
    if (!all(ok)) stop(paste('Missing packages:', paste(names(ok)[!ok], collapse=', ')))"


# Install Extra fonts
# --------------------
COPY ./extrafonts /usr/share/fonts/


# Install fonts
# --------------------
RUN echo "ttf-mscorefonts-installer msttcorefonts/accepted-mscorefonts-eula select true" | debconf-set-selections \
&& apt-get update && apt-get install -y ttf-mscorefonts-installer \
&& apt update && apt search ^fonts  | grep -o '^fonts[^/]*' | grep -vE '^(fonts-ubuntu-classic)$' | xargs apt-get install -y \
&& wget --quiet https://github.com/google/fonts/archive/main.tar.gz -O gf.tar.gz \
&& rm -rf /var/lib/apt/lists/* \
&& tar -xf gf.tar.gz \
&& mkdir -p /usr/share/fonts/truetype/google-fonts \
&& find $PWD/fonts-main/ -name "*.ttf" -exec install -m644 {} /usr/share/fonts/truetype/google-fonts/ \; || return 1 \
&& rm -f gf.tar.gz \
&& fc-cache -f && rm -rf /var/cache/*
